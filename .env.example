# ============================================================
# Environment variables template
# Copy this file to .env and fill in your values.
# .env is gitignored - NEVER commit your real keys.
# ============================================================

# Anthropic API key — used in Phase 5 to generate synthetic verbatims
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Kaggle credentials — used by scripts/download_data.sh to fetch the dataset
# Get them at: https://www.kaggle.com/settings → "Create New Token"
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Optional: OpenAI API key (alternative LLM for verbatims)
# OPENAI_API_KEY=sk-...

# Optional: MLflow tracking URI (default = local ./mlruns folder)
# MLFLOW_TRACKING_URI=http://localhost:5000
