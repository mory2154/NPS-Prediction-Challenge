# ============================================================
# Data — never commit raw or derived data
# ============================================================
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep

# ============================================================
# Models — too big and not deterministic across reruns
# ============================================================
models/*
!models/.gitkeep

# ============================================================
# Reports figures — regenerated from notebooks
# ============================================================
reports/figures/*
!reports/figures/.gitkeep

# ============================================================
# Secrets — NEVER commit
# ============================================================
.env
*.key
*.pem
.kaggle/

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb_meta

# ============================================================
# IDE
# ============================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ============================================================
# OS
# ============================================================
Thumbs.db
desktop.ini

# ============================================================
# Experiment tracking (optional)
# ============================================================
mlruns/
wandb/

# ============================================================
# Logs
# ============================================================
logs/
*.log
